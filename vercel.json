{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/auth/:action", "destination": "/api/auth?action=:action" },
    { "source": "/api/connect/:action", "destination": "/api/connect?action=:action" },
    { "source": "/api/proxy/:action", "destination": "/api/proxy?action=:action" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
