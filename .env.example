# Auth0
VITE_AUTH0_DOMAIN=adbrain-dev.jp.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id
VITE_AUTH0_AUDIENCE=https://api.adbrain.dev
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_DOMAIN=adbrain-dev.jp.auth0.com

# xAI Grok (LLM)
XAI_API_KEY=your_xai_api_key

# Google AI (Fallback LLM)
GOOGLE_AI_API_KEY=your_google_ai_api_key

# External APIs
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_dev_token

# Session
SESSION_SECRET=generate_a_random_32_byte_hex

# Vercel KV
KV_REST_API_URL=auto_injected_by_vercel
KV_REST_API_TOKEN=auto_injected_by_vercel

# Auth0 Log Streams
AUTH0_LOG_STREAM_TOKEN=generate_a_random_token
